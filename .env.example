APP_NAME="Golden Cabo Transportation"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.goldencabotransportation.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=goldencabo_db
DB_USERNAME=goldencabo_user
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=reservaciones@goldencabotransportation.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=reservaciones@goldencabotransportation.com
MAIL_FROM_NAME="Golden Cabo Transportation"

ADMIN_EMAIL=goldencabotransportation@gmail.com
